meta {
  name: 3 - Match
  type: http
  seq: 3
}

post {
  url: {{baseUrl}}/api/match
  body: json
  auth: none
}

body:json {
  {
    "resume_id": {{resume_id}},
    "job_id": {{job_id}}
  }
}

vars:pre-request {
  baseUrl: http://127.0.0.1:8000
}

assert {
  res.status: eq 200
  res.body.score: isNumber
}

docs {
  Scores the parsed resume against the parsed job. The score is cosine similarity
  between the two embeddings (0-100) — no LLM call. The explanation IS generated by
  the LLM. Uses the `resume_id` and `job_id` captured by the previous two requests,
  so run them first. Re-running returns "cached": true.
}
