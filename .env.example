# Django
# Generate a new one, e.g.: uv run python -c "from django.core.management.utils import get_random_secret_key as k; print(k())"
SECRET_KEY=change-me
DEBUG=true
ALLOWED_HOSTS=localhost,127.0.0.1

# Database — Supabase Postgres connection string (must have the pgvector extension available).
# Use the Supabase "Connection string" (URI). Note: in a real URL, special chars in the
# password must be percent-encoded.
DATABASE_URL=postgres://postgres:password@db.xxxxxxxx.supabase.co:5432/postgres

# LLM / embedding provider
LLM_PROVIDER=openai
EMBEDDING_PROVIDER=openai
OPENAI_API_KEY=sk-...
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
